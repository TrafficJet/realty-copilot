---
import Base from '../layouts/Base.astro';

const structuredData = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Rent vs Buy Calculator",
  "url": "https://realtycopilot.app/rent-vs-buy-calculator/",
  "description": "Compare the true long-term financial costs of renting versus buying a home in the US.",
  "applicationCategory": "FinanceApplication",
  "operatingSystem": "Any",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD"
  }
};
---

<Base
  title="Rent vs Buy Calculator — Is It Cheaper to Rent or Buy? | RealtyCopilot"
  description="Free rent vs buy calculator. Compare the true long-term costs of renting versus buying a home including equity buildup, opportunity cost, and break-even point."
>
  <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />

  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-10 sm:py-14">

    <!-- Page header -->
    <div class="mb-8">
      <nav class="text-sm text-gray-400 mb-3" aria-label="Breadcrumb">
        <a href="/" class="hover:text-green-600">Home</a>
        <span class="mx-2">/</span>
        <span class="text-gray-600">Rent vs Buy Calculator</span>
      </nav>
      <h1 class="text-3xl sm:text-4xl font-extrabold text-gray-900">Rent vs Buy Calculator</h1>
      <p class="mt-2 text-gray-500 text-lg">Compare the true long-term financial costs of renting versus buying.</p>
    </div>

    <!-- Inputs: two columns side by side -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">

      <!-- Renting -->
      <div class="bg-white rounded-2xl border border-gray-200 p-6 space-y-5">
        <div class="flex items-center gap-2">
          <div class="w-3 h-3 rounded-full bg-blue-500"></div>
          <h2 class="text-base font-semibold text-gray-700 uppercase tracking-wide">Renting</h2>
        </div>

        <div>
          <label for="rvb-rent" class="block text-sm font-medium text-gray-700 mb-1">Monthly Rent</label>
          <div class="relative">
            <span class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400 font-medium">$</span>
            <input type="number" id="rvb-rent" value="2200" min="0" step="50"
              class="w-full pl-7 pr-4 py-2.5 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-green-500 focus:border-transparent"
            />
          </div>
        </div>

        <div>
          <label for="rvb-rent-increase" class="block text-sm font-medium text-gray-700 mb-1">Annual Rent Increase</label>
          <div class="relative">
            <input type="number" id="rvb-rent-increase" value="3" min="0" max="20" step="0.5"
              class="w-full pl-4 pr-8 py-2.5 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-green-500 focus:border-transparent"
            />
            <span class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-400 font-medium">%</span>
          </div>
        </div>

        <div>
          <label for="rvb-renters-insurance" class="block text-sm font-medium text-gray-700 mb-1">Renter's Insurance (monthly)</label>
          <div class="relative">
            <span class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400 font-medium">$</span>
            <input type="number" id="rvb-renters-insurance" value="20" min="0" step="5"
              class="w-full pl-7 pr-4 py-2.5 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-green-500 focus:border-transparent"
            />
          </div>
        </div>

        <div>
          <label for="rvb-investment-return" class="block text-sm font-medium text-gray-700 mb-1">Investment Return on Savings</label>
          <div class="relative">
            <input type="number" id="rvb-investment-return" value="7" min="0" max="30" step="0.5"
              class="w-full pl-4 pr-8 py-2.5 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-green-500 focus:border-transparent"
            />
            <span class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-400 font-medium">%</span>
          </div>
          <p class="text-xs text-gray-400 mt-1">S&P 500 avg ~7% inflation-adjusted</p>
        </div>
      </div>

      <!-- Buying -->
      <div class="bg-white rounded-2xl border border-gray-200 p-6 space-y-5">
        <div class="flex items-center gap-2">
          <div class="w-3 h-3 rounded-full bg-green-500"></div>
          <h2 class="text-base font-semibold text-gray-700 uppercase tracking-wide">Buying</h2>
        </div>

        <div>
          <label for="rvb-price" class="block text-sm font-medium text-gray-700 mb-1">Home Purchase Price</label>
          <div class="relative">
            <span class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400 font-medium">$</span>
            <input type="number" id="rvb-price" value="400000" min="0" step="5000"
              class="w-full pl-7 pr-4 py-2.5 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-green-500 focus:border-transparent"
            />
          </div>
        </div>

        <div>
          <label for="rvb-down" class="block text-sm font-medium text-gray-700 mb-1">Down Payment</label>
          <div class="relative">
            <span class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400 font-medium">$</span>
            <input type="number" id="rvb-down" value="80000" min="0" step="5000"
              class="w-full pl-7 pr-4 py-2.5 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-green-500 focus:border-transparent"
            />
          </div>
        </div>

        <div>
          <label for="rvb-mortgage-rate" class="block text-sm font-medium text-gray-700 mb-1">Mortgage Rate</label>
          <div class="relative">
            <input type="number" id="rvb-mortgage-rate" value="6.75" min="0" max="20" step="0.125"
              class="w-full pl-4 pr-8 py-2.5 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-green-500 focus:border-transparent"
            />
            <span class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-400 font-medium">%</span>
          </div>
        </div>

        <div>
          <label for="rvb-appreciation" class="block text-sm font-medium text-gray-700 mb-1">Annual Home Appreciation</label>
          <div class="relative">
            <input type="number" id="rvb-appreciation" value="3.5" min="-10" max="20" step="0.5"
              class="w-full pl-4 pr-8 py-2.5 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-green-500 focus:border-transparent"
            />
            <span class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-400 font-medium">%</span>
          </div>
          <p class="text-xs text-gray-400 mt-1">US historical average ~3–4%</p>
        </div>

        <div>
          <label for="rvb-prop-tax-rate" class="block text-sm font-medium text-gray-700 mb-1">Property Tax Rate</label>
          <div class="relative">
            <input type="number" id="rvb-prop-tax-rate" value="1.1" min="0" max="5" step="0.1"
              class="w-full pl-4 pr-8 py-2.5 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-green-500 focus:border-transparent"
            />
            <span class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-400 font-medium">%</span>
          </div>
          <p class="text-xs text-gray-400 mt-1">US average ~1.1% of home value</p>
        </div>
      </div>
    </div>

    <!-- Time horizon -->
    <div class="bg-white rounded-2xl border border-gray-200 p-6 mb-8">
      <div class="flex flex-col sm:flex-row sm:items-center gap-4">
        <div class="flex-1">
          <label for="rvb-years" class="block text-sm font-medium text-gray-700 mb-1">
            Time Horizon: <span id="rvb-years-label" class="text-green-600 font-bold">10 years</span>
          </label>
          <input type="range" id="rvb-years" min="1" max="30" value="10" step="1"
            class="w-full h-2 bg-gray-200 rounded-full appearance-none cursor-pointer accent-green-600"
          />
          <div class="flex justify-between text-xs text-gray-400 mt-1">
            <span>1 yr</span><span>10 yr</span><span>20 yr</span><span>30 yr</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Results -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-5 mb-8">
      <div class="bg-blue-600 rounded-2xl p-6 text-white">
        <p class="text-sm font-medium text-blue-100">Total Cost of Renting</p>
        <p id="rvb-rent-cost" class="text-3xl font-extrabold mt-1 tracking-tight">—</p>
        <p class="text-sm text-blue-200 mt-1">Over <span id="rvb-rent-years">—</span> years</p>
      </div>
      <div class="bg-green-600 rounded-2xl p-6 text-white">
        <p class="text-sm font-medium text-green-100">Net Cost of Buying</p>
        <p id="rvb-buy-cost" class="text-3xl font-extrabold mt-1 tracking-tight">—</p>
        <p class="text-sm text-green-200 mt-1">After home equity</p>
      </div>
      <div class="bg-gray-800 rounded-2xl p-6 text-white">
        <p class="text-sm font-medium text-gray-300">Break-Even Point</p>
        <p id="rvb-breakeven" class="text-3xl font-extrabold mt-1 tracking-tight">—</p>
        <p class="text-sm text-gray-400 mt-1">When buying becomes cheaper</p>
      </div>
    </div>

    <!-- Verdict -->
    <div id="rvb-verdict" class="rounded-2xl p-5 mb-8 text-sm font-medium"></div>

    <!-- Year-by-year table -->
    <div class="bg-white rounded-2xl border border-gray-200 overflow-hidden">
      <div class="px-6 py-4 border-b border-gray-100">
        <h2 class="text-sm font-semibold text-gray-700 uppercase tracking-wide">Year-by-Year Comparison</h2>
      </div>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead class="bg-gray-50">
            <tr>
              <th class="px-4 py-3 text-left font-medium text-gray-500">Year</th>
              <th class="px-4 py-3 text-right font-medium text-blue-600">Cumulative Rent Cost</th>
              <th class="px-4 py-3 text-right font-medium text-green-600">Cumulative Buy Cost</th>
              <th class="px-4 py-3 text-right font-medium text-gray-500">Home Equity</th>
              <th class="px-4 py-3 text-right font-medium text-gray-500">Advantage</th>
            </tr>
          </thead>
          <tbody id="rvb-table-body" class="divide-y divide-gray-100">
            <tr><td colspan="5" class="px-4 py-6 text-center text-gray-400">Adjust inputs above</td></tr>
          </tbody>
        </table>
      </div>
    </div>

    <!-- Explanation -->
    <article class="mt-14 prose prose-gray max-w-4xl">
      <h2 class="text-2xl font-bold text-gray-900">Renting vs. Buying: What This Calculator Measures</h2>
      <p class="text-gray-600">
        The rent vs. buy decision is one of the most important financial choices you'll make. This
        calculator goes beyond the simple "is buying always better?" question by accounting for
        opportunity costs, appreciation, and cumulative costs over time.
      </p>

      <h3 class="text-lg font-semibold text-gray-800 mt-6">What's Included in the Buying Cost</h3>
      <ul class="text-gray-600 space-y-1 list-disc pl-5">
        <li>Mortgage payments (principal + interest)</li>
        <li>Property taxes (as % of home value)</li>
        <li>Homeowners insurance (~0.5% annually)</li>
        <li>Maintenance (1% of home value annually)</li>
        <li>Closing costs (estimated 3% upfront)</li>
        <li>Minus: home equity built (principal paydown + appreciation)</li>
        <li>Minus: opportunity cost of down payment invested instead</li>
      </ul>

      <h3 class="text-lg font-semibold text-gray-800 mt-6">The Break-Even Point</h3>
      <p class="text-gray-600">
        In the short term, renting is almost always cheaper — you avoid closing costs, don't tie up
        capital in a down payment, and skip maintenance expenses. But over time, buying builds equity
        while rent keeps rising. The break-even point is where cumulative ownership costs (net of
        equity) equal cumulative rental costs.
      </p>
      <p class="text-gray-600">
        If you plan to stay longer than the break-even point, buying typically makes financial sense.
        If you might move sooner, renting may be smarter.
      </p>

      <h3 class="text-lg font-semibold text-gray-800 mt-6">Non-Financial Factors</h3>
      <p class="text-gray-600">
        The financial comparison doesn't capture everything. Renting offers flexibility and freedom
        from maintenance. Buying offers stability, the ability to renovate, and potential inflation
        protection. Your personal situation, career plans, and lifestyle preferences matter as much
        as the numbers.
      </p>
    </article>
  </div>

  <script>
    const fmt = (n: number) => '$' + Math.abs(n).toFixed(0).replace(/\B(?=(\d{3})+(?!\d))/g, ',');

    const inputIds = ['rvb-rent', 'rvb-rent-increase', 'rvb-renters-insurance', 'rvb-investment-return',
      'rvb-price', 'rvb-down', 'rvb-mortgage-rate', 'rvb-appreciation', 'rvb-prop-tax-rate'];
    inputIds.forEach(id => document.getElementById(id)?.addEventListener('input', calculate));

    const yearsSlider = document.getElementById('rvb-years') as HTMLInputElement;
    yearsSlider.addEventListener('input', () => {
      (document.getElementById('rvb-years-label') as HTMLElement).textContent = yearsSlider.value + ' years';
      calculate();
    });

    function calculate() {
      const monthlyRent = parseFloat((document.getElementById('rvb-rent') as HTMLInputElement).value) || 0;
      const rentIncrease = parseFloat((document.getElementById('rvb-rent-increase') as HTMLInputElement).value) / 100 || 0;
      const rentersIns = parseFloat((document.getElementById('rvb-renters-insurance') as HTMLInputElement).value) || 0;
      const investReturn = parseFloat((document.getElementById('rvb-investment-return') as HTMLInputElement).value) / 100 || 0;
      const homePrice = parseFloat((document.getElementById('rvb-price') as HTMLInputElement).value) || 0;
      const downPayment = parseFloat((document.getElementById('rvb-down') as HTMLInputElement).value) || 0;
      const mortgageRate = parseFloat((document.getElementById('rvb-mortgage-rate') as HTMLInputElement).value) / 100 || 0;
      const appreciationRate = parseFloat((document.getElementById('rvb-appreciation') as HTMLInputElement).value) / 100 || 0;
      const propTaxRate = parseFloat((document.getElementById('rvb-prop-tax-rate') as HTMLInputElement).value) / 100 || 0;
      const years = parseInt(yearsSlider.value) || 10;

      if (homePrice <= 0 || mortgageRate <= 0) return;

      const loan = homePrice - downPayment;
      const r = mortgageRate / 12;
      const n = 30 * 12;
      const monthlyMortgage = loan * (r * Math.pow(1 + r, n)) / (Math.pow(1 + r, n) - 1);
      const closingCosts = homePrice * 0.03;

      const tableRows: Array<{
        year: number;
        cumulRent: number;
        cumulBuy: number;
        equity: number;
        advantage: string;
      }> = [];

      let cumulRentCost = 0;
      let cumulBuyCost = closingCosts + downPayment; // upfront
      let currentRent = monthlyRent;
      let loanBalance = loan;
      let currentHomeValue = homePrice;
      let rentInvestmentValue = downPayment + closingCosts; // if they invested down payment instead

      let breakEven: number | null = null;

      for (let yr = 1; yr <= 30; yr++) {
        // --- Renting ---
        for (let m = 0; m < 12; m++) {
          cumulRentCost += currentRent + rentersIns;
        }
        currentRent *= (1 + rentIncrease);

        // Opportunity cost: renter invests what they would have spent on down payment + closing
        rentInvestmentValue *= (1 + investReturn);

        // --- Buying ---
        let yearPropTax = currentHomeValue * propTaxRate;
        let yearInsurance = currentHomeValue * 0.005;
        let yearMaintenance = currentHomeValue * 0.01;
        let yearMortgage = monthlyMortgage * 12;

        cumulBuyCost += yearMortgage + yearPropTax + yearInsurance + yearMaintenance;

        // Update loan balance
        for (let m = 0; m < 12; m++) {
          const intPmt = loanBalance * r;
          const prinPmt = monthlyMortgage - intPmt;
          loanBalance = Math.max(0, loanBalance - prinPmt);
        }

        // Appreciate home value
        currentHomeValue *= (1 + appreciationRate);

        const equity = currentHomeValue - loanBalance;
        const netBuyCost = cumulBuyCost - equity;
        const netRentCost = cumulRentCost + rentInvestmentValue - (downPayment + closingCosts);

        if (breakEven === null && netBuyCost <= netRentCost) {
          breakEven = yr;
        }

        if (yr <= years) {
          const buyAdv = netRentCost - netBuyCost;
          tableRows.push({
            year: yr,
            cumulRent: netRentCost,
            cumulBuy: netBuyCost,
            equity,
            advantage: buyAdv > 0 ? `Buy +${fmt(buyAdv)}` : `Rent +${fmt(-buyAdv)}`,
          });
        }
      }

      // Get values at selected time horizon
      const lastRow = tableRows[tableRows.length - 1];
      if (!lastRow) return;

      (document.getElementById('rvb-rent-cost') as HTMLElement).textContent = fmt(lastRow.cumulRent);
      (document.getElementById('rvb-buy-cost') as HTMLElement).textContent = fmt(lastRow.cumulBuy);
      (document.getElementById('rvb-rent-years') as HTMLElement).textContent = String(years);

      const beEl = document.getElementById('rvb-breakeven') as HTMLElement;
      if (breakEven !== null) {
        beEl.textContent = `Year ${breakEven}`;
      } else {
        beEl.textContent = '> 30 yrs';
      }

      // Verdict
      const verdictEl = document.getElementById('rvb-verdict') as HTMLElement;
      const diff = lastRow.cumulRent - lastRow.cumulBuy;
      if (diff > 0) {
        verdictEl.className = 'rounded-2xl p-5 mb-8 text-sm font-medium bg-green-50 text-green-800 border border-green-200';
        verdictEl.innerHTML = `<strong>Buying is financially better</strong> over ${years} years by approximately ${fmt(diff)}. ` +
          (breakEven ? `Break-even occurs at year ${breakEven}.` : '');
      } else {
        verdictEl.className = 'rounded-2xl p-5 mb-8 text-sm font-medium bg-blue-50 text-blue-800 border border-blue-200';
        verdictEl.innerHTML = `<strong>Renting is financially better</strong> over ${years} years by approximately ${fmt(-diff)}. ` +
          (breakEven ? `Buying becomes advantageous at year ${breakEven}.` : 'Buying does not break even in 30 years at these inputs.');
      }

      // Table — show every year up to 10, then key years
      const displayYears = years <= 10
        ? tableRows
        : tableRows.filter(r => r.year <= 5 || r.year % 5 === 0 || r.year === years);

      const tbody = document.getElementById('rvb-table-body') as HTMLElement;
      tbody.innerHTML = displayYears.map(row => {
        const buyAdv = row.cumulRent - row.cumulBuy;
        const advClass = buyAdv > 0 ? 'text-green-600 font-semibold' : 'text-blue-600 font-semibold';
        return `
          <tr class="hover:bg-gray-50">
            <td class="px-4 py-3 font-medium text-gray-900">Year ${row.year}</td>
            <td class="px-4 py-3 text-right text-blue-700">${fmt(row.cumulRent)}</td>
            <td class="px-4 py-3 text-right text-green-700">${fmt(row.cumulBuy)}</td>
            <td class="px-4 py-3 text-right text-gray-700">${fmt(row.equity)}</td>
            <td class="px-4 py-3 text-right ${advClass}">${row.advantage}</td>
          </tr>
        `;
      }).join('');
    }

    calculate();
  </script>
</Base>
