---
import Base from '../layouts/Base.astro';
---
<Base title="Page Not Found | RealtyCopilot" description="The page you're looking for doesn't exist.">
  <div class="text-center py-24">
    <h1 class="text-6xl font-bold text-green-600 mb-4">404</h1>
    <p class="text-xl text-gray-600 mb-8">This page doesn't exist.</p>
    <a href="/" class="inline-block bg-green-600 text-white px-8 py-3 rounded-lg font-semibold hover:bg-green-700 transition">
      Back to Calculators
    </a>
    <div class="mt-10 flex gap-4 justify-center text-sm">
      <a href="/mortgage-calculator/" class="text-green-600 hover:underline">Mortgage Calculator</a>
      <a href="/rent-vs-buy-calculator/" class="text-green-600 hover:underline">Rent vs Buy</a>
      <a href="/blog/" class="text-green-600 hover:underline">Blog</a>
    </div>
  </div>
</Base>
